DATABASE_URL=./db.sqlite

# Site Configuration
# SITE_URL - Full URL with protocol (used for generating links and WebAuthn origin)
# Must match the URL you open in the browser (including port). Dev server default is 3100 (see package.json "dev").
# For production: your full domain with protocol (e.g., "https://yourdomain.com")
SITE_URL=http://localhost:3100

# SITE_NAME - Display name for the site (used as WebAuthn Relying Party name)
# Default: "Passwordless Demo"
SITE_NAME=Passwordless Demo

# RP_ID - Relying Party ID (automatically derived from SITE_URL hostname)
# Leave unset to use the SITE_URL hostname automatically.
# Set this only when you intentionally need a different relying party ID.
# Example override:
# RP_ID=example.com

# JWT_SECRET - Secret key for signing JWT tokens (minimum 32 characters)
# Generate a secure random value using: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
JWT_SECRET=your-secret-key-here-minimum-32-characters

# E2E only (optional): listen port for pnpm test:e2e (default 3001). Base URL is always http://localhost:<E2E_PORT>.
# E2E_PORT=3001

# E2E only (optional): set to 1 when running the built server so WebAuthn test hooks work (pnpm test:e2e sets this automatically).
# E2E_WEBAUTHN_HOOKS=1
